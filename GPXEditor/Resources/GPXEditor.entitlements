<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
    GPXeditor.entitlements

    The single source of truth for the application's macOS sandbox capabilities.
    Referenced by the project's CODE_SIGN_ENTITLEMENTS build setting; the file is
    embedded in the app bundle's signature at build time. Hardened Runtime is
    enabled separately via the ENABLE_HARDENED_RUNTIME build setting (it is a
    signing flag, not an entitlement key) and intentionally has no exception
    entitlements here.

    The full rationale for what is and is not granted lives in SECURITY.md
    ("Sandbox entitlements"). This file's keys must match that section exactly;
    any addition or removal here requires a same-commit update to SECURITY.md.
-->
<plist version="1.0">
<dict>
    <!--
        Enables App Sandbox. Without this key, every other com.apple.security.*
        capability is moot - the sandbox itself isn't running.  Mandatory for
        the project per SECURITY.md and per Decision D-007's posture statement.
    -->
    <key>com.apple.security.app-sandbox</key>
    <true/>

    <!--
        Allows the app to read files the user explicitly chooses through an
        NSOpenPanel.  Used at GPX import time (File -> Import GPX...), and
        whenever the user opens a .gpxeditor project file via Finder or the
        standard File -> Open dialog.  Without this entitlement the user could
        not bring source files into a session.

        Read-only does NOT permit writing back to the same file - that is
        what files.user-selected.read-write below covers.  We grant both
        because the document model (D-008) reads sources at import and writes
        only at save/export time, and the two operations have distinct user
        intents (Open vs. Save) that map to distinct sandbox brokers.
    -->
    <key>com.apple.security.files.user-selected.read-only</key>
    <true/>

    <!--
        Allows the app to write to files the user explicitly chooses through
        an NSSavePanel.  Used when saving .gpxeditor project files and when
        exporting GPX or KML files (M10).  Without this entitlement Save and
        Export silently fail.
    -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>

    <!--
        Allows outbound network connections.  Required for two reasons:
            1. Tile-server requests issued by Leaflet inside the WKWebView,
               for OpenStreetMap, OpenTopoMap, USGS, Esri, CyclOSM, NOAA.
            2. The OpenTopoData elevation API used by the Pin to Ground
               feature (M7).
        The sandbox treats this entitlement as binary - it cannot constrain
        which hosts are reachable.  Per-domain enforcement is implemented in
        application code (NetworkAllowList in Services/) using a
        WKContentRuleList for the WebView side and a URLSession wrapper for
        the Swift side.  See SECURITY.md "Network allow-list" for the full
        list of permitted hosts.

        We deliberately do NOT grant com.apple.security.network.server: the
        application makes outbound calls only and never accepts incoming
        connections.
    -->
    <key>com.apple.security.network.client</key>
    <true/>
</dict>
</plist>
